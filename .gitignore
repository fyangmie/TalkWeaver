# Credentials and local configuration
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/

# Editors and operating systems
.idea/
.vscode/
.DS_Store
Thumbs.db

# Models and large binary artifacts
*.ckpt
*.onnx
*.pt
*.pth
*.safetensors
models/

# Local audio and generated data
data/raw/*
data/processed/*
data/reference/*
data/synthetic/*
data/demo/*
!data/**/.gitkeep
*.wav
*.mp3
*.m4a
*.flac
*.ogg
outputs/uploads/*
!outputs/uploads/.gitkeep

# Generated outputs; keep directory markers and optional documented demos.
outputs/**/*.json
outputs/**/*.md
outputs/**/*.csv
outputs/**/*.txt
!outputs/**/.gitkeep

# Generated experiment and UI assets
experiments/results/*.csv
!experiments/results/.gitkeep
!experiments/results/ablation_results.csv
!experiments/results/term_error_results.csv
!experiments/results/latency_results.csv
assets/result_charts/*.png
!assets/result_charts/wer_comparison.png
!assets/result_charts/wder_comparison.png
!assets/result_charts/term_error_comparison.png
!assets/result_charts/latency_comparison.png
!assets/result_charts/hallucination_comparison.png
assets/screenshots/*
assets/demo_gifs/*
!assets/**/.gitkeep
