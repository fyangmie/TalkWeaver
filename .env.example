# External services are optional. Never commit the real .env file.
HF_TOKEN=

# Default OpenAI-compatible LLM configuration (DeepSeek example).
LLM_PROVIDER=deepseek
LLM_API_KEY=replace_me
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=30

# Qwen-compatible alternative:
# LLM_PROVIDER=qwen
# LLM_MODEL=qwen-plus
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI-compatible alternative:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4.1-mini
# LLM_BASE_URL=https://api.openai.com/v1

# Legacy provider-specific keys remain supported for existing deployments:
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# QWEN_API_KEY=

ASR_MODEL_SIZE=medium
USE_MOCK_ASR=false
USE_MOCK_DIARIZATION=false
USE_MOCK_LLM=true
